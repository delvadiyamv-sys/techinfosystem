<footer class="fixed-bottom bg-light py-2" id="footerAdContainer">

  <div class="container">
    <div class="row justify-content-center">

      <div class="col-lg-8 col-12" id="footerAd" style="display: none; ">

        <div id="footerCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="5000">

          <div class="carousel-inner text-center" style="overflow-x: hidden;">

            <% newAd.forEach((ad, index)=> { %>
              <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                <a href="<%= ad.link %>" target="_blank">
                  <img src="<%= ad.image %>" class="img-fluid" alt="Ad Image"
                    style="max-height:80px; width:100%; object-fit: container;" alt="Ad Image">
                </a>
              </div>
              <% }) %>

          </div>

          <!-- Arrows -->
          <button class="carousel-control-prev" data-bs-target="#footerCarousel" data-bs-slide="prev">
            <span class=""></span>
          </button>

          <button class="carousel-control-next" data-bs-target="#footerCarousel" data-bs-slide="next">
            <span class=""></span>
          </button>

        </div>

      </div>

    </div>
  </div>
  <button class="btn  btn-sm position-absolute end-0 top-0 m-2" style="z-index: 10;"
    onclick="$(this).closest('footer').fadeOut()">
    ✕
  </button>
</footer>

<script>
  // Show the footer ad after a delay (e.g., 5 seconds)
  $(document).ready(function () {
    setInterval(function () {
      $("#footerAd").fadeIn(1000).delay(3000).fadeOut(1000);
    }, 5000); // runs every 5 sec
  });

</script>

